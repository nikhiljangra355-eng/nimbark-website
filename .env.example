# ── Supabase (database for enquiries) ─────────────────────────────
# Project Settings → Data API → Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Project Settings → API Keys → service_role (secret) key.
# NEVER expose this key in frontend code — it is used server-side only.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Resend (transactional email) ──────────────────────────────────
# https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_api_key
# Optional: verified sender. Until you verify your domain in Resend,
# leave this unset and the default onboarding@resend.dev sender is used.
# After verifying nimbarkinsights.com in Resend, set e.g.:
# EMAIL_FROM=Nimbark Research Insights <enquiry@nimbarkinsights.com>

# ── Admin dashboard ────────────────────────────────────────────────
# Any long random string. Used to log in at /admin.
# Generate one: openssl rand -hex 24
ADMIN_TOKEN=choose-a-long-random-secret
